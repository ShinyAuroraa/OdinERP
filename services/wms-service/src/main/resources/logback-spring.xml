<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ── Produção / Staging: JSON estruturado para ELK ─────────────────────── -->
    <springProfile name="!test">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <includeMdcKeyName>spanId</includeMdcKeyName>
                <includeMdcKeyName>tenantId</includeMdcKeyName>
                <customFields>{"application":"wms-service"}</customFields>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
    </springProfile>

    <!-- ── Test: texto simples para legibilidade nos testes ──────────────────── -->
    <springProfile name="test">
        <appender name="TEXT_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %-5level [%X{traceId:-},%X{spanId:-}] [%X{tenantId:-N/A}] %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="TEXT_CONSOLE"/>
        </root>
    </springProfile>

</configuration>
