{
  "realm": "odin",
  "displayName": "ODIN CRM",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "roles": {
    "realm": [
      { "name": "VENDEDOR",     "description": "Sales representative" },
      { "name": "GERENTE",      "description": "Sales manager" },
      { "name": "COMPRADOR",    "description": "Buyer / procurement" },
      { "name": "FINANCEIRO",   "description": "Finance team" },
      { "name": "ATENDIMENTO",  "description": "Customer support" },
      { "name": "ADMIN",        "description": "System administrator" },
      { "name": "PII_READ",     "description": "Access to PII data (LGPD controlled)" }
    ]
  },
  "clients": [
    {
      "clientId": "odin-crm-backend",
      "name": "ODIN CRM Backend",
      "description": "Spring Boot resource server — validates JWT tokens",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect"
    },
    {
      "clientId": "odin-crm-frontend",
      "name": "ODIN CRM Frontend",
      "description": "React Next.js SPA — public client with PKCE",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "defaultRoles": [],
  "requiredCredentials": ["password"]
}
