{
  "realm": "odin",
  "enabled": true,
  "displayName": "Odin ERP",
  "displayNameHtml": "<b>Odin ERP</b>",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "roles": {
    "realm": [
      { "name": "WMS_ADMIN",    "composite": false },
      { "name": "WMS_OPERATOR", "composite": false },
      { "name": "WMS_VIEWER",   "composite": false },
      { "name": "FINANCE",      "composite": false }
    ]
  },
  "clients": [
    {
      "clientId": "wms-web",
      "name": "WMS Web Frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:3001"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "tenant-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "tenant_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "tenant_id",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "wms-service",
      "name": "WMS Backend Service",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@odin.local",
      "firstName": "Admin",
      "lastName": "WMS",
      "emailVerified": true,
      "attributes": {
        "tenant_id": ["tenant-001"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "Admin@123",
          "temporary": false
        }
      ],
      "realmRoles": ["WMS_ADMIN", "WMS_OPERATOR", "WMS_VIEWER", "FINANCE"]
    },
    {
      "username": "operador",
      "enabled": true,
      "email": "operador@odin.local",
      "firstName": "Operador",
      "lastName": "WMS",
      "emailVerified": true,
      "attributes": {
        "tenant_id": ["tenant-001"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "Operador@123",
          "temporary": false
        }
      ],
      "realmRoles": ["WMS_OPERATOR", "WMS_VIEWER"]
    },
    {
      "username": "financeiro",
      "enabled": true,
      "email": "financeiro@odin.local",
      "firstName": "Financeiro",
      "lastName": "WMS",
      "emailVerified": true,
      "attributes": {
        "tenant_id": ["tenant-001"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "Finance@123",
          "temporary": false
        }
      ],
      "realmRoles": ["FINANCE", "WMS_VIEWER"]
    }
  ]
}
